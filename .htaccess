# Force HTTPS and non-www canonical URL
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Redirect http to https
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
    # Redirect www to non-www
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]
</IfModule>

# Custom error pages
ErrorDocument 404 /404.html

# Block dotfiles and dotdirectories
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block sensitive file types ONLY in non-web directories
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Block leftover workspace directories if they reappear
    RewriteRule ^(scripts|memory|notes|data|tron-inbox|reading-tracker|skills|logs|tmp|__pycache__)(/|$) - [F,L]
    # Block Python, shell scripts, database files anywhere
    RewriteRule \.(py|sh|db|sqlite|pyc)$ - [F,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Prevent directory listing
Options -Indexes

